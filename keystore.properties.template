# Copy this file to keystore.properties and fill in your values.
# keystore.properties is git-ignored and must NEVER be committed.
#
# To generate a release keystore:
#   keytool -genkeypair -v -keystore aria-release.keystore \
#     -alias aria -keyalg RSA -keysize 2048 -validity 10000
#
# Store the keystore file somewhere safe (e.g. 1Password, not in this repo).

storeFile=../aria-release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=aria
keyPassword=YOUR_KEY_PASSWORD
